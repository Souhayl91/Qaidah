# This .gitignore file should be placed at the root of your Unity project.
#
# Recommended template: https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryProfiler/MemoryCaptures
/[Mm]emoryCaptures/

# Asset store packages/tools template
/[Aa]ssets/AssetStoreTools*

# Visual Studio / Rider / VS Code cache and autogenerated files
[Dd]ot[Nn]et/
.vs/
.idea/
.gradle/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.tlog
System.Drawing.dll
System.Threading.Tasks.Extensions.dll

# Unity3D generated meta files
/*.pidb.meta
/*.syncproj.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
